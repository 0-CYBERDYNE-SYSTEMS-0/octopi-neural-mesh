{
  "name": "octopi-wetty-system",
  "version": "1.0.0",
  "description": "Self-replicating multi-agent system using WeTTY for terminal coordination",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "dev": "nodemon src/main.js",
    "start": "node src/main.js",
    "start-all": "node scripts/start-all.js",
    "build": "node scripts/build.js",
    "test": "mocha tests/**/*.spec.js",
    "agents:start": "node src/agents/coordinator.js",
    "colony:spawn": "node scripts/spawn-colony.js",
    "cli": "node src/cli.js",
    "chat": "node src/conversational-cli.js",
    "ai-chat": "node src/ai-chatbot.js",
    "demo": "node scripts/demo.js",
    "demo:chat": "node scripts/conversational-demo.js"
  },
  "keywords": ["ai", "agents", "wetty", "terminal", "multi-agent", "self-replicating"],
  "author": "Octopi System",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "node-pty": "^1.0.0",
    "ws": "^8.14.0",
    "axios": "^1.5.0",
    "yargs": "^17.7.2",
    "winston": "^3.10.0",
    "chalk": "^5.3.0",
    "uuid": "^9.0.0",
    "lodash": "^4.17.21",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "inquirer": "^9.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "mocha": "^10.2.0",
    "chai": "^4.3.8",
    "sinon": "^15.2.0",
    "@types/node": "^20.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}